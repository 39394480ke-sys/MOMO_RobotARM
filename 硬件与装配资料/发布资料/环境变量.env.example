# Agent
ARM_AGENT_BACKEND=openai_compatible
ARM_AGENT_API_BASE=http://127.0.0.1:1234/v1
ARM_AGENT_API_KEY=
ARM_AGENT_MODEL=

# STT
ARM_STT_URL=
ARM_STT_API_KEY=

# TTS
ARM_TTS_ENABLED=false
ARM_TTS_URL=
ARM_TTS_API_KEY=

# Robot
ARM_ROBOT_PORT=/dev/tty.usbmodemXXXX
# Ubuntu ARM 开发板完成 CH343 恢复后使用：
# ARM_ROBOT_PORT=/dev/momo-servo
ARM_ROBOT_MODE=dry_run
