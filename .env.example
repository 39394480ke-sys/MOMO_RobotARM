# MOMO Robot Arm local environment
# Copy to .env on each machine. Do not commit real secrets.

# Runtime
ARM_ENV_NAME=momo_rebot
ARM_DEFAULT_MODE=dry_run
ARM_REAL_DRY_RUN=true
ARM_SERVO_BACKEND=sdk

# Web service
ARM_WEB_HOST=127.0.0.1
ARM_WEB_PORT=8010
ARM_ROBOT_API_BASE=http://127.0.0.1:8010

# Vision service
ARM_VISION_HOST=127.0.0.1
ARM_VISION_PORT=8000
ARM_VISION_LATEST_URL=http://127.0.0.1:8000/latest

# Real robot serial port. On the Ubuntu ARM board use /dev/momo-servo after CH343 setup.
ARM_ROBOT_PORT=

# Agent backend
ARM_AGENT_BACKEND=openai_compatible
ARM_AGENT_API_BASE=https://api.siliconflow.cn/v1
ARM_AGENT_API_KEY=
ARM_AGENT_MODEL=THUDM/GLM-4-9B-0414

# Speech services
ARM_STT_URL=
ARM_STT_API_KEY=
ARM_TTS_ENABLED=false
ARM_TTS_URL=
ARM_TTS_API_KEY=
